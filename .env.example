# Woodpecker server
# This must match github username for admin login to work.
WOODPECKER_ADMIN=your-github-username
WOODPECKER_HOST=https://ci.stanley.arpa
WOODPECKER_PORT=20034
# Temporarily set to true only for first-login/bootstrap if closed registration blocks admin signup.
# After successful login, set it back to false and recreate woodpecker-server.
WOODPECKER_OPEN=false
# Sync repository metadata from GitHub. This does not replace push webhooks.
WOODPECKER_POLL_INTERVAL=5m

# Public webhook host
# For Tailscale Funnel, use the device's https://<device>.<tailnet>.ts.net URL.
# Do not include a trailing slash.
WOODPECKER_EXPERT_WEBHOOK_HOST=https://your-device.your-tailnet.ts.net

# GitHub OAuth
GITHUB_CLIENT_ID=replace-me
GITHUB_CLIENT_SECRET=replace-me

# Woodpecker agent (generate this yourself with something like `cat /dev/urandom | head -n 1 | sha256sum`)
AGENT_SECRET=replace-me

# Local helper scripts
# Obtain from Woodpecker once you've logged in.
WOODPECKER_TOKEN=replace-me-with-your-woodpecker-pat
